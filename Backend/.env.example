PORT=3000
MONGO_URI=mongodb+srv://...
SERVER_HOST=http://localhost:3000
JWT_SECRET_KEY=your_jwt_secret
NODE_ENV=development

# ── AWS S3 ────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_iam_access_key
AWS_SECRET_ACCESS_KEY=your_iam_secret_key
AWS_S3_BUCKET=your-bucket-name

# ── CloudFront ────────────────────────────────────────
# Your CloudFront distribution domain (no https://)
CLOUDFRONT_DOMAIN=xxxxxxxxxxxx.cloudfront.net

# From the CloudFront key group you create (see setup guide)
CLOUDFRONT_KEY_PAIR_ID=KXXXXXXXXXXXXXXX

# RSA private key for signing CloudFront URLs.
# In a single line with \n for newlines, or use the multiline format below.
CLOUDFRONT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"
